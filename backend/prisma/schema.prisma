generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  INSTAPAY
  WALLET
  CARD
}

enum OfferType {
  PERCENTAGE
  FLAT_AMOUNT
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
}

model User {
  id                     String                   @id @default(cuid())
  firstName              String?
  lastName               String?
  name                   String?
  email                  String                   @unique
  phone                  String?
  passwordHash           String?
  role                   UserRole                 @default(CUSTOMER)
  isActive               Boolean                  @default(true)
  emailVerifiedAt        DateTime?
  addresses              Address[]
  orders                 Order[]
  productReviews         ProductReview[]
  siteReviews            SiteReview[]
  contactMessages        ContactMessage[]
  newsletterSubscriptions NewsletterSubscription[]
  notifications          Notification[]
  auditLogs              AuditLog[]               @relation("AuditActor")
  cart                   Cart?
  wishlist               Wishlist?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([role])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?
  fullName    String?
  phone       String?
  city        String
  governorate String?
  postalCode  String?
  line1       String
  line2       String?
  isDefault   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  nameEn    String?
  slug      String    @unique
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Duration {
  id        String    @id @default(cuid())
  name      String    @unique
  nameEn    String?
  slug      String    @unique
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id              String               @id @default(cuid())
  name            String
  nameEn          String?
  slug            String               @unique
  description     String?
  price           Decimal
  originalPrice   Decimal?
  discountPercent Int?
  stock           Int                  @default(0)
  sku             String               @unique
  supplier        String?
  image           String?
  featured        Boolean              @default(false)
  rating          Decimal?
  status          ProductStatus        @default(ACTIVE)
  categoryId      String
  brandId         String?
  durationId      String?
  category        Category             @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand           Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  duration        Duration?            @relation(fields: [durationId], references: [id], onDelete: SetNull)
  colorVariants   ProductColorVariant[]
  offerProducts   OfferProduct[]
  orderItems      OrderItem[]
  reviews         ProductReview[]
  cartItems       CartItem[]
  wishlistItems   WishlistItem[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([durationId])
  @@index([status])
}

model ProductColorVariant {
  id        String         @id @default(cuid())
  productId String
  name      String
  hex       String?
  sortOrder Int            @default(0)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  media     ProductMedia[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([productId, name])
  @@index([productId])
}

model ProductMedia {
  id        String              @id @default(cuid())
  variantId String
  url       String
  altText   String?
  isPrimary Boolean             @default(false)
  sortOrder Int                 @default(0)
  variant   ProductColorVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([variantId])
}

model Offer {
  id                 String       @id @default(cuid())
  title              String
  titleEn            String?
  description        String?
  imageUrl           String?
  code               String       @unique
  type               OfferType    @default(PERCENTAGE)
  discount           Decimal
  startDate          DateTime
  endDate            DateTime
  isActive           Boolean      @default(true)
  isFeatured         Boolean      @default(false)
  applicableProducts OfferProduct[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([startDate])
  @@index([endDate])
}

model OfferProduct {
  offerId    String
  productId  String
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([offerId, productId])
  @@index([productId])
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique
  userId            String?
  shippingAddressId String?
  status            OrderStatus    @default(PENDING)
  paymentMethod     PaymentMethod  @default(COD)
  transactionId     String?
  paymobOrderId     String?
  paymentResponse   Json?
  paymentProofImage String?
  subtotal          Decimal
  shippingFee       Decimal
  taxAmount         Decimal @default(0)
  discountAmount    Decimal @default(0)
  total             Decimal
  currency          String         @default("EGP")
  customerName      String
  customerEmail     String?
  customerPhone     String
  city              String
  governorate       String?
  postalCode        String?
  addressLine       String
  notes             String?
  placedAt          DateTime       @default(now())
  deliveredAt       DateTime?
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress   Address?       @relation(fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymobOrderId])
  @@index([transactionId])
  @@index([createdAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Decimal
  totalPrice    Decimal
  selectedColor String?
  productName   String?
  productSku    String?
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String?
  name       String?
  rating     Int
  comment    String
  isApproved Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

model SiteReview {
  id         String   @id @default(cuid())
  userId     String?
  name       String?
  email      String?
  quote      String
  rating     Int
  imageUrl   String?
  isApproved Boolean  @default(true)
  isFeatured Boolean  @default(false)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([isApproved])
  @@index([isFeatured])
}

model FAQ {
  id        String   @id @default(cuid())
  category  String   // e.g., "عن المنتجات", "عن الشحن"
  categoryEn String?
  question  String
  questionEn String?
  answer    String
  answerEn  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([order])
}

model InstagramGalleryItem {
  id        String   @id @default(cuid())
  username  String
  image     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

model ContactMessage {
  id        String               @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String?
  message   String
  status    ContactMessageStatus @default(NEW)
  user      User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId])
  @@index([status])
}

model NewsletterSubscription {
  id             String    @id @default(cuid())
  userId         String?
  email          String    @unique
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model StoreSettings {
  id                       String   @id @default("STORE")
  storeName                String
  storeEmail               String
  storePhone               String?
  storeAddress             String?
  city                     String?
  governorate              String?
  postalCode               String?
  shippingFee              Decimal @default(0)
  freeShippingMinimum      Decimal @default(0)
  deliveryDays             Int      @default(3)
  shippingRates            Json?
  enableShipping           Boolean  @default(true)
  enableCOD                Boolean  @default(true)
  enableInstapay           Boolean  @default(true)
  enableWallet             Boolean  @default(false)
  enablePaymob             Boolean  @default(false)
  enableTax                Boolean  @default(true)
  taxRate                  Decimal @default(0)
  walletNumber             String?
  instapayNumber           String?
  metaTitle                String?
  metaDescription          String?
  facebook                 String?
  instagram                String?
  tiktok                   String?
  whatsapp                 String?
  supportEmail             String?
  supportPhone             String?
  aboutUs                  String?
  enableEmailNotifications Boolean  @default(true)
  notifyOnNewOrder         Boolean  @default(true)
  notifyOnNewReview        Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([productId])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([wishlistId, productId])
  @@index([productId])
}
