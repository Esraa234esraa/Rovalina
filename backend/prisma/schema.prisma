generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  firstName               String?
  lastName                String?
  name                    String?
  email                   String                   @unique
  phone                   String?
  passwordHash            String?
  role                    UserRole                 @default(CUSTOMER)
  isActive                Boolean                  @default(true)
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  addresses               Address[]
  auditLogs               AuditLog[]               @relation("AuditActor")
  cart                    Cart?
  contactMessages         ContactMessage[]
  newsletterSubscriptions NewsletterSubscription[]
  notifications           Notification[]
  orders                  Order[]
  productReviews          ProductReview[]
  siteReviews             SiteReview[]
  wishlist                Wishlist?

  @@index([role])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?
  fullName    String?
  phone       String?
  city        String
  governorate String?
  postalCode  String?
  line1       String
  line2       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([userId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  nameEn    String?
  slug      String    @unique
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Duration {
  id        String    @id @default(cuid())
  name      String    @unique
  nameEn    String?
  slug      String    @unique
  icon      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id              String                @id @default(cuid())
  name            String
  nameEn          String?
  slug            String                @unique
  description     String?
  price           Decimal
  originalPrice   Decimal?
  discountPercent Int?
  stock           Int                   @default(0)
  sku             String                @unique
  supplier        String?
  image           String?
  featured        Boolean               @default(false)
  rating          Decimal?
  status          ProductStatus         @default(ACTIVE)
  categoryId      String
  brandId         String?
  durationId      String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  cartItems       CartItem[]
  offerProducts   OfferProduct[]
  orderItems      OrderItem[]
  brand           Brand?                @relation(fields: [brandId], references: [id])
  category        Category              @relation(fields: [categoryId], references: [id])
  duration        Duration?             @relation(fields: [durationId], references: [id])
  colorVariants   ProductColorVariant[]
  reviews         ProductReview[]
  wishlistItems   WishlistItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([durationId])
  @@index([status])
}

model ProductColorVariant {
  id        String         @id @default(cuid())
  productId String
  name      String
  hex       String?
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  media     ProductMedia[]

  @@unique([productId, name])
  @@index([productId])
}

model ProductMedia {
  id        String              @id @default(cuid())
  variantId String
  url       String
  altText   String?
  isPrimary Boolean             @default(false)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  variant   ProductColorVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Offer {
  id                 String         @id @default(cuid())
  title              String
  titleEn            String?
  description        String?
  imageUrl           String?
  code               String         @unique
  type               OfferType      @default(PERCENTAGE)
  discount           Decimal
  startDate          DateTime
  endDate            DateTime
  isActive           Boolean        @default(true)
  isFeatured         Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  applicableProducts OfferProduct[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([startDate])
  @@index([endDate])
}

model OfferProduct {
  offerId   String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([offerId, productId])
  @@index([productId])
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  userId            String?
  shippingAddressId String?
  status            OrderStatus   @default(PENDING)
  paymentMethod     PaymentMethod @default(COD)
  transactionId     String?
  paymobOrderId     String?
  paymentResponse   Json?
  paymentProofImage String?
  subtotal          Decimal
  shippingFee       Decimal
  taxAmount         Decimal       @default(0)
  discountAmount    Decimal       @default(0)
  total             Decimal
  currency          String        @default("EGP")
  customerName      String
  customerEmail     String?
  customerPhone     String
  city              String
  governorate       String?
  postalCode        String?
  addressLine       String
  notes             String?
  placedAt          DateTime      @default(now())
  deliveredAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  shippingAddress   Address?      @relation(fields: [shippingAddressId], references: [id])
  user              User?         @relation(fields: [userId], references: [id])
  items             OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymobOrderId])
  @@index([transactionId])
  @@index([createdAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPrice     Decimal
  totalPrice    Decimal
  selectedColor String?
  productName   String?
  productSku    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String?
  name       String?
  rating     Int
  comment    String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
}

model SiteReview {
  id         String   @id @default(cuid())
  userId     String?
  name       String?
  email      String?
  quote      String
  rating     Int
  imageUrl   String?
  isApproved Boolean  @default(true)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isApproved])
  @@index([isFeatured])
}

model FAQ {
  id         String   @id @default(cuid())
  category   String
  categoryEn String?
  question   String
  questionEn String?
  answer     String
  answerEn   String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([order])
}

model InstagramGalleryItem {
  id        String   @id @default(cuid())
  username  String
  image     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

model ContactMessage {
  id        String               @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String?
  message   String
  status    ContactMessageStatus @default(NEW)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User?                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model NewsletterSubscription {
  id             String    @id @default(cuid())
  userId         String?
  email          String    @unique
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model StoreSettings {
  id                       String   @id @default("STORE")
  storeName                String
  storeEmail               String
  storePhone               String?
  storeAddress             String?
  city                     String?
  governorate              String?
  postalCode               String?
  shippingFee              Decimal  @default(0)
  freeShippingMinimum      Decimal  @default(0)
  deliveryDays             Int      @default(3)
  shippingRates            Json?
  enableShipping           Boolean  @default(true)
  enableCOD                Boolean  @default(true)
  enableInstapay           Boolean  @default(true)
  enableWallet             Boolean  @default(false)
  enablePaymob             Boolean  @default(false)
  enableTax                Boolean  @default(true)
  taxRate                  Decimal  @default(0)
  walletNumber             String?
  instapayNumber           String?
  metaTitle                String?
  metaDescription          String?
  facebook                 String?
  instagram                String?
  tiktok                   String?
  whatsapp                 String?
  supportEmail             String?
  supportPhone             String?
  aboutUs                  String?
  enableEmailNotifications Boolean  @default(true)
  notifyOnNewOrder         Boolean  @default(true)
  notifyOnNewReview        Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  enableFreeShipping       Boolean  @default(true)
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([productId])
}

model Wishlist {
  id        String         @id @default(cuid())
  userId    String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([productId])
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  INSTAPAY
  WALLET
  CARD
}

enum OfferType {
  PERCENTAGE
  FLAT_AMOUNT
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
}
