{
  "name": "lenses-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
"build": " prisma generate && tsc"   ,
 "create:admin": "node ./scripts/create-admin.mjs",
    "seed:admin": "tsx src/seed/admin.ts",
    "dev": "tsx watch src/server.ts",
    "start": "node src/server.js",
    "start:railway": "npm run prisma:generate && npm run prisma:push:retry && npm start",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./prisma/schema.prisma",
    "prisma:push:retry": "node ./scripts/prisma-push-retry.mjs",
    "prisma:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@supabase/supabase-js": "^2.103.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.5",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.14",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
