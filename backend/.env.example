PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Local / Railway database URL
DATABASE_URL=postgresql://postgres:password@host:5432/railway?sslmode=require
DATABASE_PROVIDER=postgresql
VITE_API_URL=https://rovalina-production.up.railway.app

# Railway: Set these via Railway Variables panel instead
# DATABASE_URL=postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
# DATABASE_PROVIDER=postgresql
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
ADMIN_WHATSAPP_NUMBER=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=
WHATSAPP_PROVIDER=twilio

# EmailJS is frontend-only. Use these values in the client app, not the backend.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# Backend SMTP (recommended for guaranteed delivery from contact/newsletter endpoints)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Rovalina Store <no-reply@rovalina.com>"
CONTACT_RECEIVER_EMAIL=
