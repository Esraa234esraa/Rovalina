PORT=5000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
# Prisma datasource URL (Supabase Transaction Pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_PROVIDER=postgresql

# Supabase-only strategy in this project:
# - Use `npx prisma db push` for schema sync
# - Avoid `migrate dev`/`migrate status` when direct DB host is not reachable

# Supabase (backend/server-side only when needed)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
ADMIN_WHATSAPP_NUMBER=
TWILIO_WHATSAPP_FROM=
WHATSAPP_TO=
WHATSAPP_PROVIDER=twilio

# EmailJS is frontend-only. Use these values in the client app, not the backend.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# Backend SMTP (recommended for guaranteed delivery from contact/newsletter endpoints)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Rovalina Store <no-reply@rovalina.com>"
CONTACT_RECEIVER_EMAIL=
